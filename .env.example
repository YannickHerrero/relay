# Relay web server. Change this if the port is already in use.
PORT=43127

# Absolute location for relay.db, artifacts, uploads, and worktrees.
RELAY_DATA_DIR=~/.relay

# Public origin used for mutation-origin checks. Use your Tailscale HTTPS URL in production.
RELAY_ORIGIN=http://localhost:43127

# Worker and agent settings
RELAY_CODEX_COMMAND=codex
RELAY_WORKER_CONCURRENCY=2
RELAY_COMMAND_TIMEOUT_MS=1800000
RELAY_DEPLOYMENT_TIMEOUT_MS=3600000

# Set to true only behind HTTPS.
RELAY_SECURE_COOKIES=false
